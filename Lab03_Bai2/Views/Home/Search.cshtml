@model Lab03_Bai2.Controllers.ProductSearchModel
@{
    ViewData["Title"] = "Search";
    var products = ViewBag.Products as List<Lab03_Bai2.Controllers.Product>;
}
<h2>Tim kiem san pham</h2>
<div class="search-box">
    <form asp-action="Search" method="get">
        <input asp-for="Name" placeholder="Tên sản phẩm" />
        <input asp-for="MinPrice" type="number" placeholder="Giá từ" />
        <input asp-for="MaxPrice" type="number" placeholder="Giá đến" />
        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
    </form>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Tên sản phẩm</th>
            <th>Mô tả</th>
            <th>Giá</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in products)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td class="price">
                    @item.Price.ToString("N0") VNĐ
                </td>
            </tr>
        }
    </tbody>
</table>